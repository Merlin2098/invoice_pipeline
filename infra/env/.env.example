# Copy this file to infra/env/.env and replace the placeholder values locally.
# Do not commit real AWS credentials.

AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# Optional, only needed for temporary credentials.
AWS_SESSION_TOKEN=

# Keep this aligned with infra/terraform.tfvars unless you intentionally
# override the Terraform variable.
AWS_DEFAULT_REGION=us-east-1
